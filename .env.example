# Stellar Soroban RPC endpoint (required)
# Used by the on-chain adapter for all contract interactions.
# Examples:
#   https://soroban-testnet.stellar.org  (testnet)
#   https://rpc.mainnet.stellar.org      (mainnet)
STELLAR_RPC_URL=

# Deployed GrantStream contract ID on Stellar (required)
# The contract address used for escrow operations via the on-chain adapter.
GRANT_STREAM_CONTRACT_ID=
