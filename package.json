{
  "name": "agritrust-contracts-api",
  "version": "1.0.0",
  "description": "AgriTrust Protocol escrow API with legal-hold gating",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest --runInBand --forceExit",
    "test:coverage": "jest --runInBand --forceExit --coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "express": "^4.19.2",
    "express-validator": "^7.1.0",
    "@stellar/stellar-sdk": "^12.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "prettier": "^3.3.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/index.js"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 95,
        "functions": 95,
        "branches": 90,
        "statements": 95
      }
    }
  }
}